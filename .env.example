# Copy to .env and fill in. Both are read by flowcv.py (env vars override the file).
# RESUME_ID: the UUID in your FlowCV editor URL.
FLOWCV_RESUME_ID=00000000-0000-0000-0000-000000000000
# COOKIE: DevTools > Application > Cookies > app.flowcv.com > copy the flowcvsidapp value.
# Only the session cookie is needed (not i18n/loggedin/appVersion).
FLOWCV_COOKIE=flowcvsidapp=s%3A...
